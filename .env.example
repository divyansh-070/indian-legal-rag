# ─── LLM PROVIDER (GROQ - Free & Fast) ────────────────────────────────────────
# Get free API key at: https://console.groq.com
OLLAMA_HOST=https://api.groq.com/openai/v1
OLLAMA_MODEL=llama-3.1-8b-instant
OLLAMA_FALLBACK_MODEL=llama-3.1-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# Alternative: OpenRouter (many free models)
# OLLAMA_HOST=https://openrouter.ai/api/v1
# OLLAMA_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_API_KEY=your_openrouter_key_here

OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=4096
OLLAMA_TEMPERATURE=0.1

# ─── EMBEDDINGS ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ─── QDRANT ──────────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=legal_documents
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100

# ─── NEO4J ───────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.aura.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:your_redis_token@your-redis.upstash.io:6379

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate_using_openssl_rand_base64_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
LOG_LEVEL=INFO
API_WORKERS=1

# ─── RETRIEVAL ───────────────────────────────────────────────────────────────
TOP_K_VECTOR=20
TOP_K_GRAPH=10
TOP_K_FINAL=8
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SIMILARITY_THRESHOLD=0.65
GRAPH_HOPS=2
GRAPH_MAX_NODES=50

# ─── CRITIC ──────────────────────────────────────────────────────────────────
CRITIC_ENABLED=true
VERIFICATION_THRESHOLD=0.7
MAX_VERIFICATION_RETRIES=2

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
ENABLE_STREAMING=true
ENABLE_CACHING=true
CACHE_TTL=3600
ENABLE_RERANK=true
ENABLE_GRAPH_RAG=true
ENABLE_CRITIC=true

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_GUEST=5
RATE_LIMIT_FREE=50
RATE_LIMIT_PREMIUM=200
RATE_LIMIT_WINDOW=3600

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ─── EXTERNAL APIs (Optional) ────────────────────────────────────────────────
INDIAN_KANOON_API_KEY=
GST_PORTAL_API_KEY=
MCA_API_KEY=

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
ENABLE_STREAMING=true
ENABLE_CACHING=true
CACHE_TTL=3600
ENABLE_RERANK=true
ENABLE_GRAPH_RAG=true
ENABLE_CRITIC=true